---
import "@fontsource-variable/dm-sans";
import dmSansLatinWoff2 from "@fontsource-variable/dm-sans/files/dm-sans-latin-wght-normal.woff2";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  noindex?: boolean;
  updatedTime?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = "Abid Ali Awan - Data Scientist & Technical Writer",
  description = "Official website of Abid Ali Awan, Data Scientist and Technical Writer focused on AI systems, MLOps, and technical content.",
  canonical,
  image = "/og-image.png",
  noindex = false,
  updatedTime = new Date().toISOString(),
  structuredData,
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://abidaliawan.com");
const canonicalUrl = canonical
  ? new URL(canonical, siteUrl).toString()
  : new URL(`${Astro.url.pathname}${Astro.url.search}`, siteUrl).toString();
const imageUrl = new URL(image, siteUrl).toString();
const sitemapUrl = new URL("/sitemap.xml", siteUrl).toString();
const robots = noindex ? "noindex, nofollow" : "index, follow";
const escapedStructuredData = structuredData
  ? JSON.stringify(structuredData).replace(/</g, "\\u003c")
  : null;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="preload" as="font" type="font/woff2" href={dmSansLatinWoff2} crossorigin />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
        <meta name="generator" content={Astro.generator} />
        <meta name="author" content="Abid Ali Awan" />
        <meta name="description" content={description} />
        <meta name="robots" content={robots} />
        <meta name="googlebot" content={robots} />
        <meta name="bingbot" content={robots} />
        <link rel="canonical" href={canonicalUrl} />
        <link rel="sitemap" type="application/xml" href={sitemapUrl} />
        <meta property="og:site_name" content="Abid Ali Awan" />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={imageUrl} />
        <meta property="og:updated_time" content={updatedTime} />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={imageUrl} />
        <title>{title}</title>
        {
            escapedStructuredData && (
                <script
                    type="application/ld+json"
                    set:html={escapedStructuredData}
                />
            )
        }
        <script is:inline>
            if (localStorage.getItem("theme") === null) {
                document.documentElement.setAttribute("data-theme", "lofi");
            } else
                document.documentElement.setAttribute(
                    "data-theme",
                    localStorage.getItem("theme"),
                );
        </script>
        <script>
            import { themeChange } from "theme-change";
            themeChange();
        </script>
    </head>
    <body class="flex flex-col min-h-screen">
        <slot />
    </body>
</html>

<style is:global>
    body {
        font-family: "DM Sans Variable", sans-serif;
    }

    @media (min-width: 768px) {
        .container {
            display: flex;
            flex-wrap: wrap;
        }
    }

    .overflow-y-scroll::-webkit-scrollbar {
        width: 3px;
    }

    .overflow-y-scroll::-webkit-scrollbar-thumb {
        background-color: oklch(var(--s));
    }

    .overflow-y-scroll {
        scrollbar-width: 1px;
    }

    @media (max-width: 768px) {
        .container {
            flex-direction: column;
        }
    }

    @media (min-width: 768px) {
        .container {
            display: flex;
            flex-wrap: wrap;
        }
    }
</style>
