---
import { Icon } from "astro-icon/components";
const { timeframe, title, description, url, tags, url_name, location } =
  Astro.props;
const isExternal = /^(https?:\/\/|mailto:)/i.test(url ?? "");
const hasDescription = typeof description === "string" && description.trim().length > 0;
const hasTags = Array.isArray(tags) && tags.length > 0;
const hasLink = typeof url === "string" && url.trim().length > 0 && typeof url_name === "string" && url_name.trim().length > 0;
const isCtaLink = /^view\b/i.test(url_name ?? "");
---

<div class="card card-compact card-bordered border border-[var(--color-secondary)] w-full hover:shadow-lg transition-all my-4">
  <div class="card-body gap-5 p-6 md:p-8">
    <div class="grid gap-4 md:grid-cols-[minmax(0,1fr)_auto] md:items-start">
      <div class="min-w-0 text-left">
        <h1 class="uppercase card-title font-extrabold tracking-tighter break-words md:text-2xl">{title}</h1>
        {location && (
          <div class="flex items-center mt-2">
            <Icon name="carbon:location" class="w-4 h-4 mr-1" />
            <p class="text-sm font-light text-secondary">{location}</p>
          </div>
        )}
      </div>

      <div class="self-start md:justify-self-end md:pt-1 md:text-right">
        {timeframe && (
          <span class="date-label">{timeframe}</span>
        )}
      </div>
    </div>

    {(hasDescription || hasTags || hasLink) && (
      <div
        class:list={[
          "grid gap-5 md:grid-cols-[minmax(0,1fr)_auto]",
          hasDescription ? "md:items-start" : "md:items-center",
        ]}
      >
        <div class="min-w-0 flex-1 text-left">
          {hasDescription && (
            <article class="prose text-secondary break-words max-w-none">
              <Fragment set:html={description}></Fragment>
            </article>
          )}
          {hasTags && (
            <div class:list={["flex flex-wrap content-around gap-2", hasDescription ? "mt-4" : "mt-0"]}>
            {tags.map((item) => (
              <span class="badge text-center inline-block align-middle w-max h-max text-sm  badge-outline shadow-md mb-1" :key={item}>{item}</span>
            ))}
            </div>
          )}
        </div>

        {hasLink && (
          <div
            class:list={[
              "self-start md:justify-self-end md:text-right",
              hasDescription ? "md:self-start" : "md:self-center",
            ]}
          >
            <a
              href={url}
              target={isExternal ? "_blank" : undefined}
              rel={isExternal ? "noopener noreferrer" : undefined}
              class:list={[
                "inline-flex w-fit max-w-full items-center gap-1.5 transition md:justify-end",
                isCtaLink
                  ? "badge h-max text-center align-middle text-sm badge-outline shadow-md mb-1 hover:shadow-md"
                  : "text-sm leading-tight hover:opacity-70",
              ]}
            >
              <span class="break-words md:whitespace-nowrap">{url_name}</span>
              {url !== "#" && <Icon name="carbon:link" class="h-4 w-4 shrink-0" />}
            </a>
          </div>
        )}
      </div>
    )}
  </div>
</div>
