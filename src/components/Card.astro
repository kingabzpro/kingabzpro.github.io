---
import { Icon } from "astro-icon/components";
const { timeframe, title, description, url, tags, url_name, location } =
  Astro.props;
---

<div class="card card-compact card-bordered border border-[oklch(var(--s))] w-full md:w-112 lg:w-128 hover:shadow-lg transition-all my-4">
  <div class="card-body">
    <div class="grid grid-cols-1 gap-3 mb-2 md:grid-cols-3 md:gap-4">
      <div class="min-w-0 self-start justify-self-start text-left md:col-span-2">
        <h1 class="uppercase card-title font-extrabold tracking-tighter break-words md:text-2xl">{title}</h1>
        {location && (
          <div class="flex items-center mt-2">
            <Icon name="carbon:location" class="w-4 h-4 mr-1" />
            <p class="text-sm  font-light text-secondary">{location}</p>
          </div>
        )}
      </div>

      <div class="self-start justify-self-start md:self-center md:justify-self-end">
        {timeframe && (
          <div class="badge w-max h-max text-left badge-outline inline-block align-middle shadow-md font-mono whitespace-normal leading-tight">
            {timeframe}
          </div>
        )}
      </div>
    </div>

    <div class="grid grid-cols-1 gap-3 md:grid-cols-3 md:gap-4 md:place-items-center">
      <div class="min-w-0 self-start justify-self-start text-left md:col-span-2">
        <article class="prose text-secondary break-words">
          <Fragment set:html={description}></Fragment>
        </article>
        {Array.isArray(tags) && (
          <div class="flex flex-wrap content-around gap-2 my-4">
            {tags.map((item) => (
              <span class="badge text-center inline-block align-middle w-max h-max text-sm  badge-outline shadow-md mb-1" :key={item}>{item}</span>
            ))}
          </div>
        )}
      </div>

      <div class="self-start justify-self-start md:self-center md:justify-self-end">
        <a
          href={url}
          target="_blank"
          class="link link-hover text-sm text-left inline-flex justify-start items-center min-h-11 px-2 py-2 md:text-right md:justify-center"
        >
          {url_name}
          {url !== "#" && <Icon name="carbon:link" class="w-4 h-4 ml-2" />}
        </a>
      </div>
    </div>
  </div>
</div>
