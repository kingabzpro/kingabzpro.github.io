---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import * as about from "../pages/about/about.md";
import profileImage from "../assets/profile.png";
---

<header class="mx-auto pt-6 pb-2 relative">
  <article
    class="flex flex-col md:flex-col items-center gap-4 w-full max-w-2xl"
  >
    <button
      type="button"
      aria-label={`Toggle profile photo color for ${about.frontmatter.name}`}
      aria-pressed="false"
      data-photo-toggle
      data-photo-mode="grayscale"
      class="profile-photo flex-shrink-0 w-24 md:w-28"
    >
      <Image
        alt={`Profile picture of ${about.frontmatter.name}`}
        src={profileImage}
        width={288}
        height={288}
        quality={100}
        loading="eager"
        fetchpriority="high"
        class="profile-photo__image h-full w-full object-cover"
      />
    </button>

    <div class="text-center">
      <div class="flex justify-center items-center mb-2">
        <div class="relative flex flex-col items-center">
          <h1 class="text-3xl font-extrabold tracking-tight md:text-3xl">
            {about.frontmatter.name}
          </h1>
          {about.frontmatter.pronouns && (
            <div
              class="badge w-max text-sm font-light badge-outline shadow-lg mt-2 sm:mt-0 sm:absolute sm:top-1/2 sm:left-full sm:ml-3 sm:-translate-y-1/2"
            >
              {about.frontmatter.pronouns}
            </div>
          )}
        </div>
      </div>
      <h2 class="text-lg mb-2 text-secondary">
        {about.frontmatter.designation}
      </h2>
      <div class="flex items-center justify-center mt-1">
        <Icon name="carbon:location" class="w-4 h-4 mr-1" />
        <p class="text-sm text-secondary">{about.frontmatter.location}</p>
      </div>
    </div>
  </article>
</header>

<style>
  .profile-photo {
    border: 0;
    background: transparent;
    padding: 0;
    cursor: pointer;
  }

  .profile-photo:focus-visible {
    outline: 3px solid var(--color-primary);
    outline-offset: 8px;
    border-radius: 9999px;
  }

  .profile-photo__image {
    border-radius: 9999px;
    filter: grayscale(1);
    transition: filter 220ms ease;
  }

  .profile-photo[data-photo-mode="color"] .profile-photo__image {
    filter: grayscale(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .profile-photo__image {
      transition: none;
    }
  }
</style>

<script>
  const photoToggle = document.querySelector("[data-photo-toggle]");

  if (photoToggle instanceof HTMLButtonElement) {
    photoToggle.addEventListener("click", () => {
      const nextMode =
        photoToggle.dataset.photoMode === "color" ? "grayscale" : "color";

      photoToggle.dataset.photoMode = nextMode;
      photoToggle.setAttribute(
        "aria-pressed",
        nextMode === "color" ? "true" : "false",
      );
    });
  }
</script>
