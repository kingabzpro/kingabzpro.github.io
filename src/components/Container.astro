---
import AccordionLayout from "../layouts/AccordionLayout.astro";
import * as about from "../pages/about/about.md";
import Card from "./Card.astro";
import ContactCard from "./ContactCard.astro";
import ContactForm from "./ContactForm.astro";

type MarkdownInstance = {
  frontmatter: {
    title: string;
    date?: string;
    tags?: string[];
    url?: string;
    org?: string;
    location?: string;
    institute?: string;
    url_name?: string;
    icon?: string;
    image?: string;
  };
  compiledContent: () => string;
};

function sortMarkdownModules(modules: Record<string, unknown>): MarkdownInstance[] {
  return Object.entries(modules)
    .sort(([a], [b]) => a.localeCompare(b))
    .map(([, module]) => module as MarkdownInstance);
}

function toSortableDate(dateValue?: string): number {
  if (!dateValue) {
    return 0;
  }

  const normalized = dateValue.trim();
  const rangeStart = normalized.split(/\s[-\u2013]\s/)[0]?.trim() ?? normalized;

  const direct = Date.parse(rangeStart);
  if (!Number.isNaN(direct)) {
    return direct;
  }

  const monthYearMatch = rangeStart.match(/^([A-Za-z]{3,9})\s+(\d{4})$/);
  if (monthYearMatch) {
    const parsed = Date.parse(`${monthYearMatch[1]} 1, ${monthYearMatch[2]}`);
    return Number.isNaN(parsed) ? 0 : parsed;
  }

  const yearMatch = rangeStart.match(/^(\d{4})$/);
  if (yearMatch) {
    const parsed = Date.parse(`Jan 1, ${yearMatch[1]}`);
    return Number.isNaN(parsed) ? 0 : parsed;
  }

  return 0;
}

function parseDateRange(dateValue?: string): { start: number; end: number; current: boolean } {
  if (!dateValue) {
    return { start: 0, end: 0, current: false };
  }

  const normalized = dateValue.trim();
  const parts = normalized.split(/\s[-\u2013]\s/);
  const startPart = parts[0]?.trim() ?? "";
  const endPart = parts[1]?.trim() ?? startPart;
  const current = /present/i.test(endPart);
  const start = toSortableDate(startPart);
  const end = current ? Number.MAX_SAFE_INTEGER : toSortableDate(endPart);

  return { start, end, current };
}

const works = sortMarkdownModules(import.meta.glob("../pages/works/*.md", { eager: true }))
  .sort((a, b) => {
    const aRange = parseDateRange(a.frontmatter.date);
    const bRange = parseDateRange(b.frontmatter.date);

    if (aRange.current !== bRange.current) {
      return aRange.current ? -1 : 1;
    }

    if (aRange.end !== bRange.end) {
      return bRange.end - aRange.end;
    }

    return bRange.start - aRange.start;
  });
const projects = sortMarkdownModules(import.meta.glob("../pages/projects/*.md", { eager: true }))
  .sort((a, b) => toSortableDate(b.frontmatter.date) - toSortableDate(a.frontmatter.date));
const studies = sortMarkdownModules(import.meta.glob("../pages/studies/*.md", { eager: true }));
const certificates = sortMarkdownModules(import.meta.glob("../pages/certificates/*.md", { eager: true }));
const contact = sortMarkdownModules(import.meta.glob("../pages/contact/*.md", { eager: true }));

function isContactItem(item: MarkdownInstance): boolean {
  const link = item.frontmatter.url ?? "";
  return link.startsWith("/") || link.startsWith("mailto:") || link.startsWith("#");
}

const contactLinks = contact.filter((item) => isContactItem(item));
const socialLinks = contact.filter((item) => !isContactItem(item));
---

<div class="join join-vertical gap-1">
  <AccordionLayout title={"About"} icon={"carbon:identification"}>
    <article class="text-justify">
      <Fragment set:html={about.compiledContent()} />
    </article>
  </AccordionLayout>

  <AccordionLayout title={"Work"} icon={"carbon:construction"}>
    {
      works.map((item) => {
        return (
          <Card
            title={item.frontmatter.title}
            timeframe={item.frontmatter.date}
            description={item.compiledContent()}
            tags={item.frontmatter.tags}
            url={item.frontmatter.url}
            url_name={item.frontmatter.org}
            location={item.frontmatter.location}
          />
        );
      })
    }
  </AccordionLayout>

  <AccordionLayout title={"Studies"} icon={"carbon:education"}>
    {
      studies.map((item) => {
        return (
          <Card
            title={item.frontmatter.title}
            timeframe={item.frontmatter.date}
            location={item.frontmatter.location}
            tags={item.frontmatter.tags}
            url={item.frontmatter.url}
            url_name={item.frontmatter.institute}
          />
        );
      })
    }
  </AccordionLayout>

  <AccordionLayout title={"Projects"} icon={"carbon:tools"}>
    {
      projects.map((item) => {
        return (
          <Card
            title={item.frontmatter.title}
            timeframe={item.frontmatter.date}
            description={item.compiledContent()}
            tags={item.frontmatter.tags}
            url={item.frontmatter.url}
            url_name={"View project"}
          />
        );
      })
    }
  </AccordionLayout>

  <AccordionLayout title={"Certifications"} icon={"carbon:certificate"}>
    {
      certificates.map((item) => {
        return (
          <Card
            title={item.frontmatter.title}
            timeframe={item.frontmatter.date}
            description={item.compiledContent()}
            tags={item.frontmatter.tags}
            url={item.frontmatter.url}
            url_name={"View Certificate"}
          />
        );
      })
    }
  </AccordionLayout>

  <AccordionLayout title={"Contact"} icon={"carbon:location-person"}>
    <div class="flex flex-wrap content-around gap-4 justify-center">
      {
        contactLinks.map((item) => {
          return (
            <ContactCard
              url={item.frontmatter.url}
              url_name={item.frontmatter.title}
              icon={item.frontmatter.icon}
            />
          );
        })
      }
    </div>
    <ContactForm />
  </AccordionLayout>

  <AccordionLayout title={"Links"} icon={"carbon:share"}>
    <div class="flex flex-wrap content-around gap-4 justify-center">
      {
        socialLinks.map((item) => {
          return (
            <ContactCard
              url={item.frontmatter.url}
              url_name={item.frontmatter.title}
              icon={item.frontmatter.icon}
            />
          );
        })
      }
    </div>
  </AccordionLayout>
</div>
