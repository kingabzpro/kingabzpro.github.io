---
const getYear = () => new Date().getFullYear().toString();
---

<footer class="flex flex-col justify-center items-center bg-transparent py-4">
  <p class="flex items-center text-center font-normal text-sm text-base-content/80">
    &copy; {getYear()} developed by
    <a
      target="_blank"
      class="link ml-1 min-h-11 inline-flex items-center px-1"
      href="https://github.com/kingabzpro"
      rel="noopener noreferrer">Abid Ali Awan</a
    >
  </p>
  <p class="mt-1 text-xs text-base-content/70 transition-colors">
    <a
      target="_blank"
      class="link no-underline hover:underline min-h-11 inline-flex items-center px-1"
      href="https://github.com/mmouzo/astro-cv-esquelete"
      rel="noopener noreferrer">theme: astro-cv-esquelete</a
    >
  </p>
</footer>
